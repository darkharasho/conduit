{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "conduit",
  "version": "0.2.0",
  "identifier": "dev.conduit.app",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFM0Q5MDM4QUI4NTBENzkKUldSNURZV3JPSkE5VHBVTHdlaStWcTNRbFBTOUNwTHRsaC9YL0ZFNUVmeER0S2RjOG43QVQ1WGcK",
      "endpoints": [
        "https://github.com/darkharasho/conduit/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Conduit",
        "width": 1160,
        "height": 780,
        "minWidth": 940,
        "minHeight": 620,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "appimage"
    ],
    "externalBin": [
      "bin/conduit-daemon"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
